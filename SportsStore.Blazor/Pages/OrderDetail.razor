@page "/orders/{OrderId:int}"
@inject IOrderService OrderService
@inject NavigationManager NavigationManager

<PageTitle>Order Details - SportsStore</PageTitle>

@if (_loading)
{
    <div class="text-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (_order == null)
{
    <div class="alert alert-danger">
        <h4 class="alert-heading">Order Not Found</h4>
        <p>The order you're looking for doesn't exist.</p>
        <a href="/products" class="btn btn-primary">Browse Products</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/products">Products</a></li>
            <li class="breadcrumb-item active">Order #@_order.OrderId</li>
        </ol>
    </nav>

    <h1>Order #@_order.OrderId</h1>
    <p class="text-muted">Placed on @_order.CreatedAt.ToString("MMMM dd, yyyy 'at' h:mm tt")</p>

    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Order Items</h5>
                    <span class="badge @GetStatusBadgeClass(_order.Status)">@_order.Status</span>
                </div>
                <div class="card-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _order.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.ProductPrice.ToString("C")</td>
                                    <td>@item.LineTotal.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end"><strong>Order Total:</strong></td>
                                <td><strong>@_order.TotalAmount.ToString("C")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Customer Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>@_order.CustomerName</strong></p>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Shipping Information</h5>
                </div>
                <div class="card-body">
                    <p class="mb-1">@_order.Line1</p>
                    @if (!string.IsNullOrEmpty(_order.Line2))
                    {
                        <p class="mb-1">@_order.Line2</p>
                    }
                    @if (!string.IsNullOrEmpty(_order.Line3))
                    {
                        <p class="mb-1">@_order.Line3</p>
                    }
                    <p class="mb-1">@_order.City, @_order.State @_order.Zip</p>
                    <p class="mb-0">@_order.Country</p>
                    @if (_order.GiftWrap)
                    {
                        <div class="mt-2">
                            <span class="badge bg-info">Gift Wrap</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Order Status</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <span class="badge @GetStatusBadgeClass(_order.Status) fs-6">@_order.Status</span>
                        </div>
                    </div>
                    <small class="text-muted">
                        Status updates will be sent to your email.
                    </small>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int OrderId { get; set; }

    private OrderDto? _order;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _order = await OrderService.GetOrderAsync(OrderId);
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetStatusBadgeClass(string status)
    {
        return status.ToLower() switch
        {
            "pending" => "bg-warning text-dark",
            "inventorypending" => "bg-info text-dark",
            "paymentpending" => "bg-info text-dark",
            "shipped" => "bg-primary",
            "completed" => "bg-success",
            "cancelled" => "bg-danger",
            "failed" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
